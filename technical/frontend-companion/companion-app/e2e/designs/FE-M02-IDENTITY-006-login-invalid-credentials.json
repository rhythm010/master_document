{
  "schemaVersion": "fe-ui-test-design.v1",
  "testId": "FE-M02-IDENTITY-006",
  "title": "Login — invalid credentials shows inline error 'Incorrect email or password.'",
  "status": "FINALIZED_UI_DESIGN",
  "designMode": "IMPLEMENTED_UI_FINALIZATION",
  "milestone": "02",
  "area": "identity",
  "runtimeTargets": ["web"],
  "requiredBackend": true,
  "sourceRefs": [
    "technical/frontend-companion/companion-app/app/(auth)/login.tsx",
    "technical/frontend-companion/milestones/milestone-implementation/milestone-02-identity-flow-minimum-ui-impl.md",
    "technical/frontend-companion/frontend-backend-contract.md"
  ],
  "preconditions": [
    {
      "id": "PRE-1",
      "description": "Expo web app is running and reachable at the configured base URL."
    },
    {
      "id": "PRE-2",
      "description": "Backend is running with a working POST /auth/login endpoint that returns INVALID_CREDENTIALS for wrong passwords."
    }
  ],
  "testData": [
    {
      "id": "DATA-1",
      "name": "anyEmail",
      "strategy": "staticFixture",
      "value": "someone@example.com",
      "description": "Email does not need to exist; the INVALID_CREDENTIALS error is returned for either bad email or bad password."
    },
    {
      "id": "DATA-2",
      "name": "wrongPassword",
      "strategy": "staticFixture",
      "value": "definitely-wrong-password-xyz"
    }
  ],
  "journey": [
    {
      "step": 1,
      "action": "openApp",
      "route": "/(auth)/login",
      "description": "Open the login screen."
    },
    {
      "step": 2,
      "action": "waitForText",
      "target": { "text": "Login" },
      "description": "Confirm login screen heading is visible."
    },
    {
      "step": 3,
      "action": "fill",
      "target": { "placeholder": "Email" },
      "valueRef": "DATA-1"
    },
    {
      "step": 4,
      "action": "fill",
      "target": { "placeholder": "Password" },
      "valueRef": "DATA-2",
      "description": "Enter deliberately wrong password."
    },
    {
      "step": 5,
      "action": "click",
      "target": { "text": "Log In", "role": "button" },
      "description": "Submit login form."
    },
    {
      "step": 6,
      "action": "waitForNetworkIdle",
      "description": "Wait for the API error response."
    }
  ],
  "assertions": [
    {
      "assertion": 1,
      "afterStep": 2,
      "type": "uiVisible",
      "target": { "text": "Login" },
      "description": "Login screen is visible."
    },
    {
      "assertion": 2,
      "afterStep": 5,
      "type": "networkRequestObserved",
      "method": "POST",
      "path": "/auth/login",
      "description": "Login API call is made."
    },
    {
      "assertion": 3,
      "afterStep": 6,
      "type": "networkResponseObserved",
      "method": "POST",
      "path": "/auth/login",
      "status": 401,
      "description": "Backend returns 401 for invalid credentials."
    },
    {
      "assertion": 4,
      "afterStep": 6,
      "type": "uiVisible",
      "target": { "text": "Incorrect email or password." },
      "description": "InlineError renders the INVALID_CREDENTIALS error message."
    },
    {
      "assertion": 5,
      "afterStep": 6,
      "type": "uiNotVisible",
      "target": { "text": "Resend Verification Email" },
      "description": "Resend button does NOT appear for plain invalid credentials (only for EMAIL_NOT_VERIFIED)."
    },
    {
      "assertion": 6,
      "afterStep": 6,
      "type": "routeContains",
      "value": "/(auth)/login",
      "description": "User remains on the login screen."
    }
  ],
  "manualValidationRequired": [
    {
      "target": "ios-real-device",
      "reason": "No supported native automation runner is currently configured."
    },
    {
      "target": "android-real-device",
      "reason": "No supported native automation runner is currently configured."
    }
  ],
  "blockedTargets": [],
  "notes": [
    "No dialog or alert appears on error. Error is rendered inline via <InlineError>.",
    "The exact error text 'Incorrect email or password.' is hardcoded in login.tsx for the INVALID_CREDENTIALS error code."
  ]
}
