{
  "schemaVersion": "fe-ui-test-design.v1",
  "testId": "FE-M02-IDENTITY-003",
  "title": "Signup — duplicate email shows inline error 'An account with this email already exists.'",
  "status": "FINALIZED_UI_DESIGN",
  "designMode": "IMPLEMENTED_UI_FINALIZATION",
  "milestone": "02",
  "area": "identity",
  "runtimeTargets": ["web"],
  "requiredBackend": true,
  "sourceRefs": [
    "technical/frontend-companion/companion-app/app/(auth)/signup.tsx",
    "technical/frontend-companion/milestones/milestone-implementation/milestone-02-identity-flow-minimum-ui-impl.md",
    "technical/frontend-companion/frontend-backend-contract.md"
  ],
  "preconditions": [
    {
      "id": "PRE-1",
      "description": "Expo web app is running and reachable at the configured base URL."
    },
    {
      "id": "PRE-2",
      "description": "Backend is running with a working POST /auth/signup endpoint."
    },
    {
      "id": "PRE-3",
      "description": "An account with email DATA-1 already exists in the database (pre-seeded or created in a prior test run)."
    }
  ],
  "testData": [
    {
      "id": "DATA-1",
      "name": "existingEmail",
      "strategy": "usePreSeedCredentials",
      "description": "A verified account with this email must exist before this test runs. Can be created via API setup in beforeAll.",
      "example": "existing-user@example.com"
    },
    {
      "id": "DATA-2",
      "name": "name",
      "strategy": "staticFixture",
      "value": "Duplicate User"
    },
    {
      "id": "DATA-3",
      "name": "nickname",
      "strategy": "staticFixture",
      "value": "DupUser"
    },
    {
      "id": "DATA-4",
      "name": "password",
      "strategy": "staticFixture",
      "value": "Password123!"
    }
  ],
  "journey": [
    {
      "step": 1,
      "action": "openApp",
      "route": "/(auth)/signup",
      "description": "Open the signup screen."
    },
    {
      "step": 2,
      "action": "waitForText",
      "target": { "text": "Create Account" },
      "description": "Confirm signup screen heading is visible."
    },
    {
      "step": 3,
      "action": "fill",
      "target": { "placeholder": "Full Name" },
      "valueRef": "DATA-2"
    },
    {
      "step": 4,
      "action": "fill",
      "target": { "placeholder": "Nickname" },
      "valueRef": "DATA-3"
    },
    {
      "step": 5,
      "action": "fill",
      "target": { "placeholder": "Email" },
      "valueRef": "DATA-1",
      "description": "Enter the already-registered email."
    },
    {
      "step": 6,
      "action": "fill",
      "target": { "placeholder": "Password" },
      "valueRef": "DATA-4"
    },
    {
      "step": 7,
      "action": "click",
      "target": { "text": "Create Account", "role": "button" },
      "description": "Submit the form."
    },
    {
      "step": 8,
      "action": "waitForNetworkIdle",
      "description": "Wait for the API error response."
    }
  ],
  "assertions": [
    {
      "assertion": 1,
      "afterStep": 2,
      "type": "uiVisible",
      "target": { "text": "Create Account" },
      "description": "Signup screen is visible."
    },
    {
      "assertion": 2,
      "afterStep": 7,
      "type": "networkRequestObserved",
      "method": "POST",
      "path": "/auth/signup",
      "description": "Signup API call is made."
    },
    {
      "assertion": 3,
      "afterStep": 8,
      "type": "networkResponseObserved",
      "method": "POST",
      "path": "/auth/signup",
      "status": 409,
      "description": "Backend returns 409 for duplicate email (EMAIL_ALREADY_EXISTS)."
    },
    {
      "assertion": 4,
      "afterStep": 8,
      "type": "uiVisible",
      "target": { "text": "An account with this email already exists." },
      "description": "InlineError component renders the duplicate email error message."
    },
    {
      "assertion": 5,
      "afterStep": 8,
      "type": "routeContains",
      "value": "/(auth)/signup",
      "description": "User remains on the signup screen (no navigation on error)."
    }
  ],
  "manualValidationRequired": [
    {
      "target": "ios-real-device",
      "reason": "No supported native automation runner is currently configured."
    },
    {
      "target": "android-real-device",
      "reason": "No supported native automation runner is currently configured."
    }
  ],
  "blockedTargets": [],
  "notes": [
    "No alert dialog appears on error — the error is rendered inline via the <InlineError> component.",
    "No dialog handler is needed for this test.",
    "The backend must return error code 'EMAIL_ALREADY_EXISTS' (HTTP 409) for the error message to match exactly."
  ]
}
