{
  "testId": "JRN-001",
  "type": "journey",
  "priority": "P1",
  "scenarioName": "Two Account Creation Journey - CLIENT and COMPANION",
  "flowType": "happy",
  "linkedRequirements": [
    "identity/signup",
    "identity/verify-email",
    "identity/login",
    "identity/get-me",
    "companion-profile/get-me"
  ],
  "filePath": "src/qa/system-journeys/JRN-001-account-creation-client-and-companion.json",
  "executionMode": "api+db+events",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false,
    "mailpit": true
  },
  "objective": "Validate end-to-end account creation, verification, and login for both CLIENT and COMPANION user types",
  "preconditions": [
    "Database empty (no users)",
    "Mailpit running on localhost:8025",
    "Server running on localhost:3000",
    "At least one venue exists for roster slot population"
  ],
  "seedData": [
    {
      "entity": "venue",
      "values": {
        "id": "venue-test-001",
        "name": "Test Venue",
        "venueType": "MALL",
        "operatingHoursStart": "09:00:00",
        "operatingHoursEnd": "21:00:00"
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 30,
    "pollEveryMs": 500,
    "retryCount": 60
  },
  "steps": [
    {
      "step": 1,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/signup",
      "payload": {
        "role": "CLIENT",
        "name": "John Client",
        "nickname": "johnclient",
        "email": "client@journey.test",
        "password": "ClientPass123!",
        "biometricAuthEnabled": false
      },
      "storeResponseFields": ["id"],
      "storeAs": "clientUserId",
      "description": "CLIENT user signs up"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/signup",
      "payload": {
        "role": "COMPANION",
        "name": "Sarah Companion",
        "nickname": "sarahcomp",
        "email": "companion@journey.test",
        "password": "CompanionPass123!",
        "biometricAuthEnabled": true
      },
      "storeResponseFields": ["id"],
      "storeAs": "companionUserId",
      "description": "COMPANION user signs up"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "users",
      "where": {
        "field": "email",
        "value": "client@journey.test"
      },
      "description": "Verify CLIENT user created in database"
    },
    {
      "step": 4,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "users",
      "where": {
        "field": "email",
        "value": "companion@journey.test"
      },
      "description": "Verify COMPANION user created in database"
    },
    {
      "step": 5,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "companion_profiles",
      "where": {
        "field": "user_id",
        "value": "{{companionUserId}}"
      },
      "description": "Verify companion profile created for COMPANION user"
    },
    {
      "step": 6,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "companion_id",
        "value": "{{companionUserId}}"
      },
      "description": "Verify roster slots populated for COMPANION user"
    },
    {
      "step": 7,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "description": "Retrieve CLIENT verification email from Mailpit",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "client@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "clientVerificationToken"
    },
    {
      "step": 8,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "description": "Retrieve COMPANION verification email from Mailpit",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "companion@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "companionVerificationToken"
    },
    {
      "step": 9,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{clientVerificationToken}}"
      },
      "description": "CLIENT verifies email"
    },
    {
      "step": 10,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{companionVerificationToken}}"
      },
      "description": "COMPANION verifies email"
    },
    {
      "step": 11,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "users",
      "where": {
        "field": "email",
        "value": "client@journey.test"
      },
      "description": "Verify CLIENT email_verified is true"
    },
    {
      "step": 12,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "users",
      "where": {
        "field": "email",
        "value": "companion@journey.test"
      },
      "description": "Verify COMPANION email_verified is true"
    },
    {
      "step": 13,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "payload": {
        "email": "client@journey.test",
        "password": "ClientPass123!"
      },
      "storeResponseFields": ["accessToken"],
      "storeAs": "clientAccessToken",
      "description": "CLIENT logs in successfully"
    },
    {
      "step": 14,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "payload": {
        "email": "companion@journey.test",
        "password": "CompanionPass123!"
      },
      "storeResponseFields": ["accessToken"],
      "storeAs": "companionAccessToken",
      "description": "COMPANION logs in successfully"
    },
    {
      "step": 15,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/users/me",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "description": "CLIENT fetches own profile"
    },
    {
      "step": 16,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/users/me",
      "headers": {
        "Authorization": "Bearer {{companionAccessToken}}"
      },
      "description": "COMPANION fetches own profile with companion profile data"
    },
    {
      "step": 17,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/companion-profiles/me",
      "headers": {
        "Authorization": "Bearer {{companionAccessToken}}"
      },
      "description": "COMPANION fetches companion-specific profile"
    },
    {
      "step": 18,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/companion-profiles/me",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "description": "CLIENT attempts to fetch companion profile (should fail with 403)"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 1,
        "statusCode": 201,
        "bodyFields": {
          "role": "CLIENT",
          "email": "client@journey.test",
          "emailVerified": false
        }
      },
      {
        "step": 2,
        "statusCode": 201,
        "bodyFields": {
          "role": "COMPANION",
          "email": "companion@journey.test",
          "emailVerified": false,
          "biometricAuthEnabled": true
        }
      },
      {
        "step": 9,
        "statusCode": 200,
        "bodyFields": {
          "status": "VERIFIED"
        }
      },
      {
        "step": 10,
        "statusCode": 200,
        "bodyFields": {
          "status": "VERIFIED"
        }
      },
      {
        "step": 13,
        "statusCode": 200,
        "requiredKeys": ["accessToken", "user"],
        "bodyFields": {
          "user": {
            "role": "CLIENT",
            "emailVerified": true
          }
        }
      },
      {
        "step": 14,
        "statusCode": 200,
        "requiredKeys": ["accessToken", "user"],
        "bodyFields": {
          "user": {
            "role": "COMPANION",
            "emailVerified": true,
            "biometricAuthEnabled": true
          }
        }
      },
      {
        "step": 15,
        "statusCode": 200,
        "bodyFields": {
          "role": "CLIENT",
          "email": "client@journey.test"
        },
        "mustNotHaveKeys": ["companionProfile"]
      },
      {
        "step": 16,
        "statusCode": 200,
        "bodyFields": {
          "role": "COMPANION",
          "email": "companion@journey.test"
        },
        "requiredKeys": ["companionProfile"],
        "nestedChecks": {
          "companionProfile": {
            "isActive": true,
            "designation": "CAPTAIN or VICE_CAPTAIN"
          }
        }
      },
      {
        "step": 17,
        "statusCode": 200,
        "requiredKeys": ["id", "userId", "designation", "isActive", "languages", "profilePictureUrl", "averageRating"],
        "bodyFields": {
          "isActive": true,
          "averageRating": 0.0
        }
      },
      {
        "step": 18,
        "statusCode": 403,
        "bodyFields": {
          "code": "FORBIDDEN"
        }
      }
    ],
    "db": [
      {
        "step": 3,
        "table": "users",
        "checks": [
          "row exists",
          "role=CLIENT",
          "email=client@journey.test",
          "email_verified=false initially"
        ]
      },
      {
        "step": 4,
        "table": "users",
        "checks": [
          "row exists",
          "role=COMPANION",
          "email=companion@journey.test",
          "email_verified=false initially",
          "biometric_auth_enabled=true"
        ]
      },
      {
        "step": 5,
        "table": "companion_profiles",
        "checks": [
          "row exists",
          "user_id matches companionUserId",
          "designation in (CAPTAIN, VICE_CAPTAIN)",
          "is_active=true",
          "languages=[]",
          "profile_picture_url=''",
          "average_rating=0.00"
        ]
      },
      {
        "step": 6,
        "table": "roster_slots",
        "checks": [
          "at least 1 row exists",
          "companion_id matches companionUserId",
          "status=AVAILABLE",
          "booking_id=null"
        ]
      },
      {
        "step": 11,
        "table": "users",
        "checks": [
          "row exists",
          "email=client@journey.test",
          "email_verified=true"
        ]
      },
      {
        "step": 12,
        "table": "users",
        "checks": [
          "row exists",
          "email=companion@journey.test",
          "email_verified=true"
        ]
      }
    ],
    "external": [
      {
        "step": 7,
        "description": "CLIENT verification email sent",
        "checks": [
          "email exists",
          "to=client@journey.test",
          "contains verification token"
        ]
      },
      {
        "step": 8,
        "description": "COMPANION verification email sent",
        "checks": [
          "email exists",
          "to=companion@journey.test",
          "contains verification token"
        ]
      }
    ],
    "mustNotOccur": [
      "CLIENT user has companion_profile row",
      "COMPANION user without companion_profile row",
      "login succeeds before email verification",
      "CLIENT can access companion-only endpoints"
    ]
  },
  "cleanup": [
    "Delete roster_slots for COMPANION user",
    "Delete companion_profiles for COMPANION user",
    "Delete both user rows",
    "Clear Mailpit messages",
    "Clear rate limiter state"
  ],
  "passCriteria": [
    "Both CLIENT and COMPANION users created successfully",
    "Verification emails sent for both users",
    "Email verification works for both users",
    "Login succeeds after verification for both users",
    "Valid JWT tokens issued for both users",
    "CLIENT user has no companion profile",
    "COMPANION user has companion profile with correct defaults",
    "COMPANION user has roster slots populated",
    "Authorization boundaries enforced (CLIENT cannot access companion endpoints)",
    "Biometric preference persisted for COMPANION",
    "Companion designation assigned (CAPTAIN or VICE_CAPTAIN)"
  ]
}
