{
  "testId": "MOD-IDENTITY-009",
  "type": "module",
  "moduleOwner": "identity",
  "priority": "P1",
  "scenarioName": "Login Rejects Invalid Credentials",
  "flowType": "negative",
  "linkedRequirement": "identity/login",
  "filePath": "src/modules/identity/__tests__/MOD-IDENTITY-009-login-invalid-credentials.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate login rejects incorrect password",
  "preconditions": ["Verified user exists"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-verified",
        "role": "CLIENT",
        "email": "verified@test.com",
        "password": "CorrectPassword123!",
        "passwordHash": "bcrypt_hashed_CorrectPassword123!",
        "emailVerified": true
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "payload": {
        "email": "verified@test.com",
        "password": "WrongPassword123!"
      }
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 1,
        "statusCode": 401,
        "bodyFields": {
          "code": "INVALID_CREDENTIALS"
        },
        "requiredKeys": ["code", "message"]
      }
    ],
    "mustNotOccur": ["accessToken returned", "login success"]
  },
  "cleanup": ["Delete seeded user", "Clear rate limiter state"],
  "passCriteria": [
    "API returns 401 INVALID_CREDENTIALS",
    "No access token issued",
    "Failed attempt recorded for rate limiting"
  ]
}
