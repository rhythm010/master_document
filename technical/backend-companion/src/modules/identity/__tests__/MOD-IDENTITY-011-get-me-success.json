{
  "testId": "MOD-IDENTITY-011",
  "type": "module",
  "moduleOwner": "identity",
  "priority": "P1",
  "scenarioName": "Get Me Returns User Profile",
  "flowType": "happy",
  "linkedRequirement": "identity/get-me",
  "filePath": "src/modules/identity/__tests__/MOD-IDENTITY-011-get-me-success.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate GET /users/me returns authenticated user profile with companion profile if COMPANION role",
  "preconditions": ["Verified COMPANION user exists with profile"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-companion",
        "role": "COMPANION",
        "name": "Test Companion",
        "nickname": "testcomp",
        "email": "companion@test.com",
        "passwordHash": "hashed",
        "emailVerified": true,
        "biometricAuthEnabled": false
      }
    },
    {
      "entity": "companion_profile",
      "values": {
        "id": "profile-001",
        "userId": "user-companion",
        "designation": "CAPTAIN",
        "isActive": true,
        "languages": ["ENGLISH", "ARABIC"],
        "profilePictureUrl": "https://example.com/pic.jpg",
        "averageRating": 4.5
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "TestExecutor",
      "actionType": "generateToken",
      "tokenType": "AUTH",
      "userId": "user-companion",
      "role": "COMPANION",
      "email": "companion@test.com",
      "storeAs": "authToken"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/users/me",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      }
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 2,
        "statusCode": 200,
        "bodyFields": {
          "id": "user-companion",
          "role": "COMPANION",
          "name": "Test Companion",
          "nickname": "testcomp",
          "email": "companion@test.com",
          "emailVerified": true,
          "biometricAuthEnabled": false,
          "companionProfile": {
            "id": "profile-001",
            "userId": "user-companion",
            "designation": "CAPTAIN",
            "isActive": true,
            "languages": ["ENGLISH", "ARABIC"],
            "profilePictureUrl": "https://example.com/pic.jpg",
            "averageRating": 4.5
          }
        },
        "requiredKeys": ["id", "createdAt", "companionProfile"]
      }
    ],
    "mustNotOccur": ["passwordHash in response"]
  },
  "cleanup": ["Delete companion_profile row", "Delete user row"],
  "passCriteria": [
    "API returns 200",
    "User profile returned with all fields",
    "Companion profile included for COMPANION role",
    "Password hash never exposed",
    "Average rating converted to number"
  ]
}
