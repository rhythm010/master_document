    },
    {
      "step": 2,
      "actor": "System",
      "actionType": "authorization",
      "expectedBehavior": [
        "Verify booking exists",
        "Verify caller is CLIENT role and booking owner"
      ],
      "layman": "System verifies authorization"
    },
    {
      "step": 3,
      "actor": "System",
      "actionType": "dbQuery",
      "expectedBehavior": [
        "Fetch booking by ID",
