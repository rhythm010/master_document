      "description": "Booking status is CANCELLED",
      "seedOverride": {
        "booking": {
          "status": "CANCELLED",
          "startAt": "{{FUTURE_TIMESTAMP_WITHIN_5H_WINDOW}}"
        }
      },
      "expectedCompanions": null
    },
    {
      "variantId": "B",
      "description": "Booking status is COMPLETED",
      "seedOverride": {
        "booking": {
          "status": "COMPLETED",
          "startAt": "{{PAST_TIMESTAMP}}"
        }
      },
      "expectedCompanions": null
    }
  ],
