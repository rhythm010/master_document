{
  "testId": "MOD-MATCHING-002",
  "artifactStatus": "FINALIZED_EXECUTABLE",
  "scenarioName": "Com-Match Context - Presence Not Arrived (400)",
  "flowType": "edge",
  "linkedRequirement": "matching-flow/com-match-context",
  "filePath": "technical/backend-companion/src/modules/matching/__tests__/MOD-MATCHING-002-com-match-context-presence-not-arrived.json",
  "executionMode": "api+db+auth",
  "objective": "Reject com-match context when either companion has not arrived",
  "featureSdsVersion": "matching-flow_current.md v1.0.0",
  "testVariants": [
    {
      "variantId": "A",
      "description": "Captain presence_status=ASSIGNED",
      "seedOverride": {
        "booking_companion_assignment": {
          "designation": "CAPTAIN",
          "presence_status": "ASSIGNED"
        }
      }
    },
    {
      "variantId": "B",
      "description": "Vice Captain presence_status=ASSIGNED",
      "seedOverride": {
        "booking_companion_assignment": {
          "designation": "VICE_CAPTAIN",
          "presence_status": "ASSIGNED"
        }
      }
    }
  ],
  "seedData": [
    {
      "entity": "user",
      "role": "COMPANION",
      "count": 2
    },
    {
      "entity": "companion_profile",
      "designation": "CAPTAIN",
      "count": 1
    },
    {
      "entity": "companion_profile",
      "designation": "VICE_CAPTAIN",
      "count": 1
    },
    {
      "entity": "booking",
      "status": "CONFIRMED",
      "count": 1
    },
    {
      "entity": "booking_companion_assignment",
      "count": 2,
      "fields": {
        "presence_status": "ASSIGNED",
        "self_match_status": "NOT_MATCHED",
        "client_match_status": "WAITING_FOR_CLIENT"
      },
      "description": "One companion not ARRIVED (variant-specific override)"
    }
  ],
  "steps": [
    {
      "step": 1,
      "actor": "Companion",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/bookings/:bookingId/com-match/context",
      "authType": "Bearer",
      "pathParams": {
        "bookingId": "{{BOOKING_ID}}"
      },
      "layman": "Companion requests com-match context before both companions have arrived"
    },
    {
      "step": 2,
      "actor": "System",
      "actionType": "validation",
      "expectedBehavior": [
        "Detect at least one assignment presence_status != ARRIVED",
        "Return PRESENCE_NOT_ARRIVED"
      ],
      "layman": "System blocks the context until both companions have arrived"
    },
    {
      "step": 3,
      "actor": "System",
      "actionType": "apiResponse",
      "expectedStatus": 400,
      "expectedErrorCode": "PRESENCE_NOT_ARRIVED",
      "layman": "System returns a presence-not-arrived error"
    }
  ],
  "assertions": {
    "api": [
      "Response status is 400",
      "Error code is PRESENCE_NOT_ARRIVED"
    ],
    "businessRules": [
      "Com-match context requires both companions ARRIVED",
      "QR/PIN must not be exposed when presence is incomplete"
    ]
  },
  "openQuestions": [],
  "notes": [
    "Covers the presence gate for com-match context"
  ]
}
