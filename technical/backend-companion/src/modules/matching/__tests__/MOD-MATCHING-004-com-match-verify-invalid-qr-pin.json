      "description": "QR verification with wrong QR",
      "payloadTemplate": {
        "verificationMethod": "QR",
        "qrCode": "{{INVALID_QR}}"
      }
    },
    {
      "variantId": "B",
      "description": "PIN verification with wrong PIN",
      "payloadTemplate": {
        "verificationMethod": "PIN",
        "pinCode": "{{INVALID_PIN}}"
      }
    }
  ],
  "seedData": [
    {
      "entity": "user",
      "role": "COMPANION",
      "count": 2
    },
    {
      "entity": "companion_profile",
      "designation": "CAPTAIN",
      "count": 1
    },
    {
      "entity": "companion_profile",
      "designation": "VICE_CAPTAIN",
      "count": 1
    },
    {
      "entity": "booking",
      "status": "CONFIRMED",
      "count": 1,
      "fields": {
        "comMatchQrCode": "{{BOOKING_COM_MATCH_QR}}",
        "comMatchPinCode": "{{BOOKING_COM_MATCH_PIN}}"
      }
    },
    {
      "entity": "booking_companion_assignment",
      "count": 2,
      "fields": {
        "presence_status": "ARRIVED",
        "self_match_status": "NOT_MATCHED"
      }
    }
  ],
  "steps": [
    {
      "step": 1,
      "actor": "ViceCaptain",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/bookings/:bookingId/com-match/verify",
      "authType": "Bearer",
      "pathParams": {
        "bookingId": "{{BOOKING_ID}}"
      },
      "requiredPayloadFields": [
        "verificationMethod"
      ],
      "payloadRules": {
        "qrCode": "Wrong value",
        "pinCode": "Wrong value"
      },
      "layman": "Vice captain submits an incorrect QR or PIN"
    },
    {
      "step": 2,
      "actor": "System",
      "actionType": "validation",
      "expectedBehavior": [
        "Detect invalid QR/PIN",
        "Return INVALID_QR_OR_PIN"
      ],
      "layman": "System rejects the invalid verification attempt"
    },
    {
      "step": 3,
      "actor": "System",
      "actionType": "apiResponse",
      "expectedStatus": 400,
      "expectedErrorCode": "INVALID_QR_OR_PIN",
      "layman": "System returns an invalid QR/PIN error"
    }
  ],
  "assertions": {
    "api": [
      "Response status is 400",
      "Error code is INVALID_QR_OR_PIN"
    ],
    "db": [
      "Companion assignments remain self_match_status=NOT_MATCHED"
    ],
    "businessRules": [
      "QR/PIN must match booking values",
