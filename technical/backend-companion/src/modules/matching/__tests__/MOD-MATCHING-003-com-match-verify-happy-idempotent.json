{
  "testId": "MOD-MATCHING-003",
  "artifactStatus": "FINALIZED_EXECUTABLE",
  "scenarioName": "Com-Match Verify - Happy Path and Idempotent",
  "flowType": "happy",
  "linkedRequirement": "matching-flow/com-match-verify",
  "filePath": "technical/backend-companion/src/modules/matching/__tests__/MOD-MATCHING-003-com-match-verify-happy-idempotent.json",
  "executionMode": "api+db+auth",
  "objective": "Validate VICE_CAPTAIN can verify com-match via QR/PIN and idempotent success when already matched",
  "featureSdsVersion": "matching-flow_current.md v1.0.0",
  "testVariants": [
    {
      "variantId": "A",
      "description": "QR verification succeeds",
      "payloadTemplate": {
        "verificationMethod": "QR",
        "qrCode": "{{BOOKING_COM_MATCH_QR}}"
      }
    },
    {
      "variantId": "B",
      "description": "PIN verification succeeds",
      "payloadTemplate": {
        "verificationMethod": "PIN",
        "pinCode": "{{BOOKING_COM_MATCH_PIN}}"
      }
    },
    {
      "variantId": "C",
      "description": "Idempotent: assignments already MATCHED",
      "seedOverride": {
        "booking_companion_assignment": {
          "self_match_status": "MATCHED"
        }
      },
      "payloadTemplate": {
        "verificationMethod": "QR",
        "qrCode": "{{BOOKING_COM_MATCH_QR}}"
      }
    }
  ],
  "seedData": [
    {
      "entity": "user",
      "role": "COMPANION",
      "count": 2
    },
    {
      "entity": "companion_profile",
      "designation": "CAPTAIN",
      "count": 1
    },
    {
      "entity": "companion_profile",
      "designation": "VICE_CAPTAIN",
      "count": 1
    },
    {
      "entity": "booking",
      "status": "CONFIRMED",
      "count": 1,
      "fields": {
        "comMatchQrCode": "{{BOOKING_COM_MATCH_QR}}",
        "comMatchPinCode": "{{BOOKING_COM_MATCH_PIN}}"
      }
    },
    {
      "entity": "booking_companion_assignment",
      "count": 2,
      "fields": {
        "presence_status": "ARRIVED",
        "self_match_status": "NOT_MATCHED",
        "client_match_status": "WAITING_FOR_CLIENT"
      }
    }
  ],
  "steps": [
    {
      "step": 1,
      "actor": "ViceCaptain",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/bookings/:bookingId/com-match/verify",
      "authType": "Bearer",
      "pathParams": {
        "bookingId": "{{BOOKING_ID}}"
      },
      "requiredPayloadFields": [
        "verificationMethod"
      ],
      "payloadRules": {
        "verificationMethod": "QR or PIN",
        "qrCode": "Required when verificationMethod=QR; must match booking.comMatchQrCode",
        "pinCode": "Required when verificationMethod=PIN; must match booking.comMatchPinCode"
      },
      "layman": "Vice captain submits the captain's QR or PIN to confirm the companion match"
    },
    {
      "step": 2,
      "actor": "System",
      "actionType": "authorization",
      "expectedBehavior": [
        "Caller is assigned to booking",
        "Caller designation is VICE_CAPTAIN"
      ],
      "layman": "System confirms only the vice captain can verify the com-match"
    },
    {
      "step": 3,
      "actor": "System",
      "actionType": "validation",
      "expectedBehavior": [
        "Both companions presence_status=ARRIVED",
        "If already MATCHED, return idempotent success",
        "If not matched, booking.status must be CONFIRMED"
      ],
      "layman": "System validates presence and idempotency before updating match status"
    },
    {
      "step": 4,
      "actor": "System",
      "actionType": "dbTransaction",
      "expectedBehavior": [
        "Update both assignments self_match_status=MATCHED",
        "Ensure update count is 2"
      ],
      "layman": "System atomically marks both companions as matched"
    },
    {
      "step": 5,
      "actor": "System",
      "actionType": "apiResponse",
      "expectedStatus": 200,
      "expectedResponseFields": [
        "bookingId",
        "selfMatchStatus"
      ],
      "layman": "System returns a successful com-match verification response"
    }
  ],
  "assertions": {
    "api": [
      "Response status is 200",
      "selfMatchStatus is MATCHED"
    ],
    "db": [
      "Both companion assignments have self_match_status=MATCHED"
    ],
    "businessRules": [
      "Only VICE_CAPTAIN can verify com-match",
      "Verification requires ARRIVED presence",
      "Idempotent success when already MATCHED"
    ]
  },
  "openQuestions": [],
  "notes": [
    "Covers QR/PIN verification and idempotency path",
    "Matches matching.service.verifyComMatch logic"
  ]
}
