{
  "testId": "MOD-COMPANION-PROFILE-008",
  "artifactStatus": "FINALIZED_EXECUTABLE",
  "type": "module",
  "moduleOwner": "companion-profile",
  "priority": "P2",
  "scenarioName": "Toggle Active to True Success",
  "flowType": "happy",
  "linkedRequirement": "companion-profile/toggle-active",
  "filePath": "src/modules/companion-profile/__tests__/MOD-COMPANION-PROFILE-008-toggle-active-true.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate PATCH /companion-profiles/toggle-active sets isActive to true",
  "preconditions": ["Companion user exists with inactive profile"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-companion",
        "role": "COMPANION",
        "email": "companion@test.com",
        "password_hash": "hashed",
        "email_verified": true
      }
    },
    {
      "entity": "companion_profile",
      "values": {
        "id": "profile-001",
        "user_id": "user-companion",
        "designation": "VICE_CAPTAIN",
        "is_active": false,
        "languages": [],
        "profile_picture_url": "",
        "average_rating": 0.0
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "TestExecutor",
      "actionType": "generateToken",
      "tokenType": "AUTH",
      "userId": "user-companion",
      "role": "COMPANION",
      "email": "companion@test.com",
      "storeAs": "authToken",
      "layman": "Generate authentication token for the companion user"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "PATCH",
      "endpoint": "/companion-profiles/toggle-active",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "payload": {
        "isActive": true
      },
      "layman": "Companion toggles their active status to true to go online"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "companion_profiles",
      "where": {
        "field": "user_id",
        "value": "user-companion"
      },
      "layman": "Verify the isActive flag was set to true in the database"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 2,
        "statusCode": 200,
        "bodyFields": {
          "isActive": true
        }
      }
    ],
    "db": [
      {
        "step": 3,
        "table": "companion_profiles",
        "checks": ["row exists", "is_active=true"]
      }
    ],
    "mustNotOccur": ["other profile fields changed"]
  },
  "cleanup": ["Delete companion_profile row", "Delete user row"],
  "passCriteria": [
    "API returns 200",
    "isActive updated to true in database",
    "Companion can now participate in matching",
    "Idempotent operation"
  ]
}
