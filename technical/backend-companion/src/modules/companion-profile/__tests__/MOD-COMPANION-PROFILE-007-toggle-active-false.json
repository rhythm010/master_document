{
  "testId": "MOD-COMPANION-PROFILE-007",
  "type": "module",
  "moduleOwner": "companion-profile",
  "priority": "P1",
  "scenarioName": "Toggle Active to False Success",
  "flowType": "happy",
  "linkedRequirement": "companion-profile/toggle-active",
  "filePath": "src/modules/companion-profile/__tests__/MOD-COMPANION-PROFILE-007-toggle-active-false.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate PATCH /companion-profiles/toggle-active sets isActive to false",
  "preconditions": ["Companion user exists with active profile"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-companion",
        "role": "COMPANION",
        "email": "companion@test.com",
        "password_hash": "hashed",
        "email_verified": true
      }
    },
    {
      "entity": "companion_profile",
      "values": {
        "id": "profile-001",
        "user_id": "user-companion",
        "designation": "CAPTAIN",
        "is_active": true,
        "languages": ["ENGLISH"],
        "profile_picture_url": "",
        "average_rating": 4.0
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "TestExecutor",
      "actionType": "generateToken",
      "tokenType": "AUTH",
      "userId": "user-companion",
      "role": "COMPANION",
      "email": "companion@test.com",
      "storeAs": "authToken"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "PATCH",
      "endpoint": "/companion-profiles/toggle-active",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "payload": {
        "isActive": false
      }
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "companion_profiles",
      "where": {
        "field": "user_id",
        "value": "user-companion"
      }
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 2,
        "statusCode": 200,
        "bodyFields": {
          "isActive": false
        }
      }
    ],
    "db": [
      {
        "step": 3,
        "table": "companion_profiles",
        "checks": ["row exists", "is_active=false"]
      }
    ],
    "mustNotOccur": ["other profile fields changed"]
  },
  "cleanup": ["Delete companion_profile row", "Delete user row"],
  "passCriteria": [
    "API returns 200",
    "isActive updated to false in database",
    "Other fields unchanged",
    "Companion blocked from matching initiation (enforced elsewhere)"
  ]
}
