{
  "testId": "MOD-COMPANION-PROFILE-006",
  "artifactStatus": "FINALIZED_EXECUTABLE",
  "type": "module",
  "moduleOwner": "companion-profile",
  "priority": "P1",
  "scenarioName": "Update Profile Rejects Invalid Language",
  "flowType": "negative",
  "linkedRequirement": "companion-profile/update-profile",
  "filePath": "src/modules/companion-profile/__tests__/MOD-COMPANION-PROFILE-006-invalid-language.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate PATCH /companion-profiles/me rejects invalid language codes",
  "preconditions": ["Companion user exists with profile"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-companion",
        "role": "COMPANION",
        "email": "companion@test.com",
        "password_hash": "hashed",
        "email_verified": true
      }
    },
    {
      "entity": "companion_profile",
      "values": {
        "id": "profile-001",
        "user_id": "user-companion",
        "designation": "CAPTAIN",
        "is_active": true,
        "languages": ["ENGLISH"],
        "profile_picture_url": "",
        "average_rating": 0.0
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "TestExecutor",
      "actionType": "generateToken",
      "tokenType": "AUTH",
      "userId": "user-companion",
      "role": "COMPANION",
      "email": "companion@test.com",
      "storeAs": "authToken",
      "layman": "Generate authentication token for the companion user"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "PATCH",
      "endpoint": "/companion-profiles/me",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "payload": {
        "languages": ["ENGLISH", "SPANISH"]
      },
      "layman": "Companion attempts to update languages with an invalid language code"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "companion_profiles",
      "where": {
        "field": "user_id",
        "value": "user-companion"
      },
      "layman": "Verify the languages field was not changed in the database"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 2,
        "statusCode": 400,
        "bodyFields": {
          "code": "INVALID_LANGUAGE"
        }
      }
    ],
    "db": [
      {
        "step": 3,
        "table": "companion_profiles",
        "checks": ["row exists", "languages still = [ENGLISH]"]
      }
    ],
    "mustNotOccur": ["languages updated with invalid value"]
  },
  "cleanup": ["Delete companion_profile row", "Delete user row"],
  "passCriteria": [
    "API returns 400 INVALID_LANGUAGE",
    "Languages unchanged in database",
    "Only ENGLISH and ARABIC allowed"
  ]
}
