{
  "testId": "MOD-COMPANION-PROFILE-005",
  "artifactStatus": "FINALIZED_EXECUTABLE",
  "type": "module",
  "moduleOwner": "companion-profile",
  "priority": "P2",
  "scenarioName": "Update Profile Picture URL Success",
  "flowType": "happy",
  "linkedRequirement": "companion-profile/update-profile",
  "filePath": "src/modules/companion-profile/__tests__/MOD-COMPANION-PROFILE-005-update-picture-url.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false
  },
  "objective": "Validate PATCH /companion-profiles/me updates profilePictureUrl",
  "preconditions": ["Companion user exists with profile"],
  "seedData": [
    {
      "entity": "user",
      "values": {
        "id": "user-companion",
        "role": "COMPANION",
        "email": "companion@test.com",
        "password_hash": "hashed",
        "email_verified": true
      }
    },
    {
      "entity": "companion_profile",
      "values": {
        "id": "profile-001",
        "user_id": "user-companion",
        "designation": "VICE_CAPTAIN",
        "is_active": true,
        "languages": ["ENGLISH"],
        "profile_picture_url": "",
        "average_rating": 0.0
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 5,
    "pollEveryMs": 500,
    "retryCount": 10
  },
  "steps": [
    {
      "step": 1,
      "actor": "TestExecutor",
      "actionType": "generateToken",
      "tokenType": "AUTH",
      "userId": "user-companion",
      "role": "COMPANION",
      "email": "companion@test.com",
      "storeAs": "authToken",
      "layman": "Generate authentication token for the companion user"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "PATCH",
      "endpoint": "/companion-profiles/me",
      "headers": {
        "Authorization": "Bearer {{authToken}}"
      },
      "payload": {
        "profilePictureUrl": "https://storage.companion.app/profiles/user-companion/picture.jpg"
      },
      "layman": "Companion updates their profile picture URL"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "companion_profiles",
      "where": {
        "field": "user_id",
        "value": "user-companion"
      },
      "layman": "Verify the profile picture URL was updated in the database"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 2,
        "statusCode": 200,
        "bodyFields": {
          "profilePictureUrl": "https://storage.companion.app/profiles/user-companion/picture.jpg"
        }
      }
    ],
    "db": [
      {
        "step": 3,
        "table": "companion_profiles",
        "checks": [
          "row exists",
          "profile_picture_url=https://storage.companion.app/profiles/user-companion/picture.jpg"
        ]
      }
    ],
    "mustNotOccur": ["languages field changed"]
  },
  "cleanup": ["Delete companion_profile row", "Delete user row"],
  "passCriteria": [
    "API returns 200",
    "Profile picture URL updated in database",
    "Other fields unchanged"
  ]
}
