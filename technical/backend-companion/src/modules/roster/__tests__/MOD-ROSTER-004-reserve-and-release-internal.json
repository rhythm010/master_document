      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 20,
    "pollEveryMs": 500,
    "retryCount": 40
  },
  "steps": [
    {
      "step": 1,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/roster-slots/reserve",
      "headers": {
        "X-Internal-Token": "{{INTERNAL_API_TOKEN}}"
      },
      "payload": {
        "venueId": "b6e64090-73b1-42d3-b29b-8934c584c4d0",
        "startAt": "2026-04-26T10:00:00.000Z",
        "endAt": "2026-04-26T12:00:00.000Z",
        "bookingId": "7353bc7e-7b8b-422f-9e9e-1fc6316ab2f5"
      },
      "storeResponseFields": ["captainSlotId", "viceCaptainSlotId"]
    },
    {
      "step": 2,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "id",
        "value": "f62a597b-da60-42a2-847e-be33ab24f5da"
      },
      "description": "Verify CAPTAIN roster_slot row booked + booking_id set (query by seeded CAPTAIN roster_slot id)"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "id",
        "value": "df971cbd-9e92-4d3e-ba6a-4467c56b54bb"
      },
      "description": "Verify VICE_CAPTAIN roster_slot row booked + booking_id set (query by seeded VICE_CAPTAIN roster_slot id)"
    },
    {
      "step": 4,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/roster-slots/release",
      "headers": {
        "X-Internal-Token": "{{INTERNAL_API_TOKEN}}"
      },
      "payload": {
        "bookingId": "7353bc7e-7b8b-422f-9e9e-1fc6316ab2f5"
      }
    },
    {
      "step": 5,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "id",
        "value": "f62a597b-da60-42a2-847e-be33ab24f5da"
      },
      "description": "Verify CAPTAIN roster_slot released (AVAILABLE + booking_id NULL) (query by seeded CAPTAIN roster_slot id)"
    },
    {
      "step": 6,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "id",
        "value": "df971cbd-9e92-4d3e-ba6a-4467c56b54bb"
      },
      "description": "Verify VICE_CAPTAIN roster_slot released (AVAILABLE + booking_id NULL) (query by seeded VICE_CAPTAIN roster_slot id)"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 1,
        "statusCode": 200,
        "requiredKeys": ["reserved", "captainSlotId", "viceCaptainSlotId"],
        "bodyFields": {
          "reserved": true,
          "captainSlotId": "f62a597b-da60-42a2-847e-be33ab24f5da",
          "viceCaptainSlotId": "df971cbd-9e92-4d3e-ba6a-4467c56b54bb"
        },
        "checks": [
          "captainSlotId is uuid",
          "viceCaptainSlotId is uuid",
          "captainSlotId != viceCaptainSlotId"
        ]
      },
      {
        "step": 4,
        "statusCode": 200,
        "requiredKeys": ["released", "slotsReleased"],
        "bodyFields": {
          "released": true,
          "slotsReleased": 2
        }
      }
    ],
    "db": [
      {
        "step": 2,
        "table": "roster_slots",
        "checks": [
          "row exists",
          "status=BOOKED",
          "booking_id=7353bc7e-7b8b-422f-9e9e-1fc6316ab2f5",
          "venue_id=b6e64090-73b1-42d3-b29b-8934c584c4d0"
        ]
      },
      {
        "step": 3,
        "table": "roster_slots",
        "checks": [
          "row exists",
          "status=BOOKED",
          "booking_id=7353bc7e-7b8b-422f-9e9e-1fc6316ab2f5",
          "venue_id=b6e64090-73b1-42d3-b29b-8934c584c4d0"
        ]
      },
      {
        "step": 5,
        "table": "roster_slots",
        "checks": ["row exists", "status=AVAILABLE", "booking_id=null"]
      },
      {
        "step": 6,
        "table": "roster_slots",
        "checks": ["row exists", "status=AVAILABLE", "booking_id=null"]
      }
    ],
    "mustNotOccur": ["only one slot reserved", "slotsReleased != 2"]
  },
  "cleanup": [
    "Delete roster_slots f62a597b-da60-42a2-847e-be33ab24f5da, df971cbd-9e92-4d3e-ba6a-4467c56b54bb (and any reserved rows)",
    "Delete companion_profiles 3ecb5ee3-cf69-4258-b8f1-bd96756beddf, f5a31616-894c-426f-a2dd-a70c41d230eb",
    "Delete users 96d51d90-a7f6-4eb9-8214-fcad3e7503e9, 1ab29da9-a6ac-4c09-9536-3f0fb530b1de",
    "Delete booking 7353bc7e-7b8b-422f-9e9e-1fc6316ab2f5",
    "Delete user 4ec72e3a-102b-4786-97b3-dc89ccd74554",
    "Delete venue b6e64090-73b1-42d3-b29b-8934c584c4d0"
  ],
  "passCriteria": [
    "Reserve returns 200 reserved=true and 2 slot IDs (matching seeded CAPTAIN/VICE_CAPTAIN roster_slot ids)",
    "Both referenced roster_slots are BOOKED and booking_id is set after reserve",
    "Release returns 200 released=true and slotsReleased=2",
    "Both roster_slots revert to AVAILABLE and booking_id cleared after release"
  ]
}
