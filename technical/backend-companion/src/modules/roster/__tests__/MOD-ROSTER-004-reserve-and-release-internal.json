{
  "testId": "MOD-ROSTER-004",
  "type": "module",
  "moduleOwner": "roster",
  "priority": "P1",
  "scenarioName": "POST /roster-slots/reserve then /release updates slot status and bookingId (internal)",
  "flowType": "happy",
  "linkedRequirement": "roster/reserve-slots",
  "filePath": "src/modules/roster/__tests__/MOD-ROSTER-004-reserve-and-release-internal.json",
  "executionMode": "api+db",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false,
    "mailpit": false
  },
  "objective": "Reserve one CAPTAIN and one VICE_CAPTAIN slot for a venue/time window, then release them, validating DB status + booking_id set/cleared.",
  "preconditions": [
    "Server running on localhost:3000",
    "Internal API token available as env var INTERNAL_API_TOKEN and injectable into request header via {{INTERNAL_API_TOKEN}}",
    "Seed runner inserts seedData into DB before steps"
  ],
