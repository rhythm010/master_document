      "values": {
        "id": "f62a597b-da60-42a2-847e-be33ab24f5da",
        "venueId": "b6e64090-73b1-42d3-b29b-8934c584c4d0",
        "companionId": "96d51d90-a7f6-4eb9-8214-fcad3e7503e9",
        "bookingId": null,
        "startAt": "2026-04-26T10:00:00.000Z",
        "endAt": "2026-04-26T12:00:00.000Z",
        "status": "AVAILABLE"
