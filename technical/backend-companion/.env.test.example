# Test Environment Configuration - EXAMPLE
# Copy this file to .env.test and replace placeholder values with actual tokens
# Run this to generate tokens: node -e "const c=require('crypto');console.log('JWT_SECRET='+c.randomBytes(32).toString('hex'));console.log('INTERNAL_API_TOKEN='+c.randomBytes(32).toString('hex'))"

# Node Environment
NODE_ENV=test

# Server Configuration
PORT=3000
API_BASE_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://companion:companion@localhost:5433/companion_test
DB_POOL_SIZE=10

# Authentication & Security
# REPLACE WITH GENERATED TOKEN (64 characters)
JWT_SECRET=REPLACE_WITH_GENERATED_64_CHAR_HEX_TOKEN
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
BCRYPT_ROUNDS=4

# Internal API Token (for test runner internal endpoints)
# REPLACE WITH GENERATED TOKEN (64 characters)
INTERNAL_API_TOKEN=REPLACE_WITH_GENERATED_64_CHAR_HEX_TOKEN

# Email Service (Mailpit for testing)
MAILPIT_BASE_URL=http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025

# Feature Flags
ENABLE_BACKGROUND_JOBS=false
