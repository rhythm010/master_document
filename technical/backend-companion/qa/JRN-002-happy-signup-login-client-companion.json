{
  "testId": "JRN-002",
  "type": "journey",
  "priority": "P1",
  "scenarioName": "Happy path: CLIENT signup -> COMPANION signup -> verify both emails -> CLIENT login -> COMPANION login",
  "flowType": "happy",
  "linkedRequirements": ["identity/signup", "identity/verify-email", "identity/login"],
  "filePath": "qa/JRN-002-happy-signup-login-client-companion.json",
  "executionMode": "api+db+external",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false,
    "mailpit": true
  },
  "objective": "Validate end-to-end happy path for CLIENT + COMPANION account creation and subsequent logins, including required email verification for login success.",
  "testData": {
    "runIdPlaceholder": "{{RUN_ID}}",
    "emailTemplates": {
      "clientEmail": "client.jrn002+{{RUN_ID}}@journey.test",
      "companionEmail": "companion.jrn002+{{RUN_ID}}@journey.test"
    },
    "credentials": {
      "clientPassword": "ClientPass123!",
      "companionPassword": "CompanionPass123!"
    }
  },
  "preconditions": [
    "Server running on localhost:3000",
    "Mailpit running on localhost:8025",
    "No pre-existing users with emails client.jrn002+{{RUN_ID}}@journey.test or companion.jrn002+{{RUN_ID}}@journey.test"
  ],
  "seedData": [],
  "waitPolicy": {
    "maxSeconds": 30,
    "pollEveryMs": 500,
    "retryCount": 60
  },
  "steps": [
    {
      "step": 1,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/signup",
      "payload": {
        "role": "CLIENT",
        "name": "Journey Client",
        "nickname": "journeyclient-{{RUN_ID}}",
        "email": "client.jrn002+{{RUN_ID}}@journey.test",
        "password": "ClientPass123!",
        "biometricAuthEnabled": false
      },
      "storeResponseFields": ["id"],
      "storeAs": "clientUserId",
      "description": "CLIENT signs up"
    },
    {
      "step": 2,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/signup",
      "payload": {
        "role": "COMPANION",
        "name": "Journey Companion",
        "nickname": "journeycompanion-{{RUN_ID}}",
        "email": "companion.jrn002+{{RUN_ID}}@journey.test",
        "password": "CompanionPass123!",
        "biometricAuthEnabled": true
      },
      "storeResponseFields": ["id"],
      "storeAs": "companionUserId",
      "description": "COMPANION signs up"
    },
    {
      "step": 3,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "description": "Retrieve CLIENT verification email from Mailpit and extract token",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "client.jrn002+{{RUN_ID}}@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "clientVerificationToken"
    },
    {
      "step": 4,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "description": "Retrieve COMPANION verification email from Mailpit and extract token",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "companion.jrn002+{{RUN_ID}}@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "companionVerificationToken"
    },
    {
      "step": 5,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{clientVerificationToken}}"
      },
      "description": "CLIENT verifies email (required for login)"
    },
    {
      "step": 6,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{companionVerificationToken}}"
      },
      "description": "COMPANION verifies email (required for login)"
    },
    {
      "step": 7,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "payload": {
        "email": "client.jrn002+{{RUN_ID}}@journey.test",
        "password": "ClientPass123!"
      },
      "storeResponseFields": ["accessToken"],
      "storeAs": "clientAccessToken",
      "description": "CLIENT logs in successfully (email must be verified)"
    },
    {
      "step": 8,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "payload": {
        "email": "companion.jrn002+{{RUN_ID}}@journey.test",
        "password": "CompanionPass123!"
      },
      "storeResponseFields": ["accessToken"],
      "storeAs": "companionAccessToken",
      "description": "COMPANION logs in successfully (email must be verified)"
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 1,
        "statusCode": 201,
        "requiredKeys": ["id", "createdAt"],
        "bodyFields": {
          "role": "CLIENT",
          "email": "client.jrn002+{{RUN_ID}}@journey.test",
          "emailVerified": false,
          "biometricAuthEnabled": false
        }
      },
      {
        "step": 2,
        "statusCode": 201,
        "requiredKeys": ["id", "createdAt"],
        "bodyFields": {
          "role": "COMPANION",
          "email": "companion.jrn002+{{RUN_ID}}@journey.test",
          "emailVerified": false,
          "biometricAuthEnabled": true
        }
      },
      {
        "step": 5,
        "statusCode": 200,
        "bodyFields": {"status": "VERIFIED"}
      },
      {
        "step": 6,
        "statusCode": 200,
        "bodyFields": {"status": "VERIFIED"}
      },
      {
        "step": 7,
        "statusCode": 200,
        "requiredKeys": ["accessToken", "user"],
        "bodyFields": {
          "user": {"role": "CLIENT", "emailVerified": true}
        }
      },
      {
        "step": 8,
        "statusCode": 200,
        "requiredKeys": ["accessToken", "user"],
        "bodyFields": {
          "user": {"role": "COMPANION", "emailVerified": true, "biometricAuthEnabled": true}
        }
      }
    ],
    "external": [
      {
        "step": 3,
        "description": "CLIENT verification email exists in Mailpit",
        "checks": [
          "email exists",
          "to=client.jrn002+{{RUN_ID}}@journey.test",
          "contains verification token"
        ]
      },
      {
        "step": 4,
        "description": "COMPANION verification email exists in Mailpit",
        "checks": [
          "email exists",
          "to=companion.jrn002+{{RUN_ID}}@journey.test",
          "contains verification token"
        ]
      }
    ],
    "mustNotOccur": ["login succeeds before email verification"]
  },
  "cleanup": [
    "Delete user rows for clientUserId and companionUserId",
    "Clear Mailpit messages"
  ],
  "passCriteria": [
    "CLIENT signup returns 201 with role=CLIENT and emailVerified=false",
    "COMPANION signup returns 201 with role=COMPANION and emailVerified=false",
    "Mailpit contains verification emails for both users",
    "Both /auth/verify-email calls return 200 VERIFIED",
    "CLIENT login returns 200 and includes accessToken and user.role=CLIENT",
    "COMPANION login returns 200 and includes accessToken and user.role=COMPANION"
  ]
}
