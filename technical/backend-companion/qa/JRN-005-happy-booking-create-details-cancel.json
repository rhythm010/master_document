      "payloadRules": {
        "role": "COMPANION",
        "nameTemplate": "journey companion B {{RUN_ID}}",
        "nicknameTemplate": "journeycompanionB-jrn005-{{RUN_ID}}",
        "emailTemplate": "companionb.jrn005+{{RUN_ID}}@journey.test",
        "passwordRule": "Generate strong password and store for reuse",
        "passwordStoreAs": "companionBPassword",
        "biometricAuthEnabled": false,
        "emailNormalizationNote": "Use lowercase; system normalizes emails to lowercase"
      }
    },
    {
      "step": 6,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "companionb.jrn005+{{RUN_ID}}@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "companionBVerificationToken",
      "description": "Extract COMPANION B verification token from Mailpit",
      "layman": "Confirm the second verification email arrived and grab the token."
    },
    {
      "step": 7,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{companionBVerificationToken}}"
      },
      "description": "Verify COMPANION B email",
      "layman": "Verify the second companion email so they can log in."
    },
    {
      "step": 8,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "storeResponseFields": ["accessToken"],
      "storeAs": "companionBAccessToken",
      "description": "Login COMPANION B",
      "layman": "Log the second companion in and store their access token.",
