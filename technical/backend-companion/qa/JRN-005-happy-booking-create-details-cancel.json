{
  "testId": "JRN-005",
  "type": "journey",
  "priority": "P1",
  "scenarioName": "Happy path: create CAPTAIN+VICE roster -> CLIENT booking create -> details -> cancel (idempotent)",
  "flowType": "happy",
  "linkedRequirements": [
    "identity/signup",
    "identity/verify-email",
    "identity/login",
    "roster/populate-for-companion",
    "roster/get-availability",
    "booking/create",
    "booking/details",
    "booking/cancel"
  ],
  "filePath": "qa/JRN-005-happy-booking-create-details-cancel.json",
  "executionMode": "api+db+external",
  "environmentRequirements": {
    "server": "local-running",
    "database": "test_db",
    "queue": false,
    "eventListener": false,
    "mailpit": true
  },
  "objective": "Prove a client can create a booking that allocates a CAPTAIN+VICE duo (via roster), then fetch booking details, then cancel the booking (and cancelling again is idempotent).",
  "preconditions": [
    "Server running on localhost:3000",
    "Mailpit running on localhost:8025",
    "INTERNAL_API_TOKEN exported in shell running test-validator",
    "Test DB should be reasonably clean so companion designation balancing yields at least one CAPTAIN and one VICE_CAPTAIN among the created companions"
  ],
  "testData": {
    "runIdPlaceholder": "{{RUN_ID}}",
    "venue": {
      "venueId": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a",
      "name": "Journey Venue - Booking",
      "operatingHoursStart": "00:00:00",
      "operatingHoursEnd": "23:59:59"
    },
    "emails": {
      "clientEmail": "client.jrn005+{{RUN_ID}}@journey.test",
      "companionAEmail": "companiona.jrn005+{{RUN_ID}}@journey.test",
      "companionBEmail": "companionb.jrn005+{{RUN_ID}}@journey.test"
    },
    "dateRules": {
      "TODAY_DATE_YMD": "Provided automatically by the JS runner as {{TODAY_DATE_YMD}} (computed using process.env.TZ, default UTC)."
    },
    "bookingRules": {
      "startAt": "Use the first availableStartTime returned by the availability call",
      "endAt": "Server derives endAt = startAt + 2 hours"
    }
  },
  "seedData": [
    {
      "entity": "venue",
      "values": {
        "id": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a",
        "name": "Journey Venue - Booking",
        "address": "500 Booking Road, Dubai",
        "venueType": "MALL",
        "latitude": 25.2048,
        "longitude": 55.2708,
        "operatingHoursStart": "00:00:00",
        "operatingHoursEnd": "23:59:59"
      }
    }
  ],
  "waitPolicy": {
    "maxSeconds": 60,
    "pollEveryMs": 500,
    "retryCount": 120
  },
  "steps": [
    {
      "step": 1,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/signup",
      "storeResponseFields": ["id"],
      "storeAs": "companionAUserId",
      "description": "COMPANION A signs up",
      "layman": "Create the first companion account.",
      "requiredPayloadFields": [
        "role",
        "name",
        "nickname",
        "email",
        "password",
        "biometricAuthEnabled"
      ],
      "payloadRules": {
        "role": "COMPANION",
        "nameTemplate": "journey companion A {{RUN_ID}}",
        "nicknameTemplate": "journeycompanionA-jrn005-{{RUN_ID}}",
        "emailTemplate": "companiona.jrn005+{{RUN_ID}}@journey.test",
        "passwordRule": "Generate strong password and store for reuse",
        "passwordStoreAs": "companionAPassword",
        "biometricAuthEnabled": false,
        "emailNormalizationNote": "Use lowercase; system normalizes emails to lowercase"
      }
    },
    {
      "step": 2,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "companiona.jrn005+{{RUN_ID}}@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "companionAVerificationToken",
      "description": "Extract COMPANION A verification token from Mailpit",
      "layman": "Confirm the verification email arrived and grab the token."
    },
    {
      "step": 3,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{companionAVerificationToken}}"
      },
      "description": "Verify COMPANION A email",
      "layman": "Verify the companion email so they can log in."
    },
    {
      "step": 4,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "storeResponseFields": ["accessToken"],
      "storeAs": "companionAAccessToken",
      "description": "Login COMPANION A",
      "layman": "Log the companion in and store their access token.",
      "requiredPayloadFields": ["email", "password"],
      "payloadRules": {
        "emailTemplate": "companiona.jrn005+{{RUN_ID}}@journey.test",
        "passwordFromStoreKey": "companionAPassword",
        "passwordRule": "Reuse the same password from signup"
      }
    },
    {
      "step": 5,
      "actor": "APIClient",
      "actionType": "apiRequest",
