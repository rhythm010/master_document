      "method": "POST",
      "endpoint": "/auth/signup",
      "storeResponseFields": ["id"],
      "storeAs": "clientUserId",
      "description": "CLIENT signs up",
      "layman": "Create the client account that will make the booking.",
      "requiredPayloadFields": [
        "role",
        "name",
        "nickname",
        "email",
        "password",
        "biometricAuthEnabled"
      ],
      "payloadRules": {
        "role": "CLIENT",
        "nameTemplate": "journey client {{RUN_ID}}",
        "nicknameTemplate": "journeyclient-jrn005-{{RUN_ID}}",
        "emailTemplate": "client.jrn005+{{RUN_ID}}@journey.test",
        "passwordRule": "Generate strong password and store for reuse",
        "passwordStoreAs": "clientPassword",
        "biometricAuthEnabled": false,
        "emailNormalizationNote": "Use lowercase; system normalizes emails to lowercase"
      }
    },
    {
      "step": 12,
      "actor": "TestExecutor",
      "actionType": "externalCheck",
      "endpoint": "http://localhost:8025/api/v1/messages",
      "validateEmailTo": "client.jrn005+{{RUN_ID}}@journey.test",
      "extractTokenFromEmail": true,
      "storeAs": "clientVerificationToken",
      "description": "Extract CLIENT verification token from Mailpit",
      "layman": "Confirm the client verification email arrived and grab the token."
    },
    {
      "step": 13,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/auth/verify-email",
      "queryParams": {
        "token": "{{clientVerificationToken}}"
      },
      "description": "Verify CLIENT email",
      "layman": "Verify the client email so login can succeed."
    },
    {
      "step": 14,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/auth/login",
      "storeResponseFields": ["accessToken"],
      "storeAs": "clientAccessToken",
      "description": "Login CLIENT",
      "layman": "Log the client in and store their access token.",
      "requiredPayloadFields": ["email", "password"],
      "payloadRules": {
        "emailTemplate": "client.jrn005+{{RUN_ID}}@journey.test",
        "passwordFromStoreKey": "clientPassword",
        "passwordRule": "Reuse the same password from signup"
      }
    },
    {
      "step": 15,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/availability",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "queryParams": {
        "venueId": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a",
        "date": "{{TODAY_DATE_YMD}}"
      },
      "storeResponseFields": ["availableStartTimes"],
      "storeAs": "availableStartTimes",
      "description": "Get today's availability at the venue",
      "layman": "Ask the system what booking start times are available today at this venue."
    },
    {
      "step": 16,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/bookings",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "storeResponseFields": ["id"],
      "storeAs": "bookingId",
      "description": "Create booking for first availableStartTime",
      "layman": "Create a booking at the first available start time. The backend should allocate a CAPTAIN+VICE companion duo.",
      "requiredPayloadFields": ["venueId", "startAt"],
      "payloadRules": {
        "venueId": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a",
        "startAtFromStoreArrayKey": "availableStartTimes",
        "startAtPickStrategy": "first"
      }
    },
    {
      "step": 17,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "GET",
      "endpoint": "/bookings/{{bookingId}}/details",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "description": "Fetch booking details",
      "layman": "Confirm the booking exists and retrieve its details."
    },
    {
      "step": 18,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/bookings/{{bookingId}}/cancel",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "description": "Cancel booking (first time)",
      "layman": "Cancel the booking. The backend should release the reserved roster slots."
    },
    {
      "step": 19,
      "actor": "APIClient",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/bookings/{{bookingId}}/cancel",
      "headers": {
        "Authorization": "Bearer {{clientAccessToken}}"
      },
      "description": "Cancel booking (second time, idempotent)",
      "layman": "Cancelling again should still succeed and keep the booking cancelled."
    },
    {
      "step": 20,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "bookings",
      "where": {
        "field": "id",
        "value": "{{bookingId}}"
      },
      "description": "DB check: booking row exists and is CANCELLED",
      "layman": "Verify in the database that the booking status is CANCELLED."
    },
    {
      "step": 21,
      "actor": "TestExecutor",
      "actionType": "dbQuery",
      "target": "roster_slots",
      "where": {
        "field": "booking_id",
        "value": "{{bookingId}}"
      },
      "description": "DB check: no roster_slots still reference this booking",
      "layman": "Verify the roster slots were released (no slot should still point to this booking id)."
    }
  ],
  "assertions": {
    "api": [
      {
        "step": 16,
        "statusCode": 201,
        "requiredKeys": ["id", "status", "clientId", "venueId", "startAt", "endAt", "createdAt"],
        "bodyFields": {
          "status": "CONFIRMED",
          "venueId": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a"
        }
      },
      {
        "step": 17,
        "statusCode": 200,
        "requiredKeys": ["id", "status", "clientId", "venueId", "startAt", "endAt", "createdAt"],
        "bodyFields": {
          "venueId": "c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a"
        }
      },
      {
        "step": 18,
        "statusCode": 200,
        "bodyFields": {
          "status": "CANCELLED"
        }
      },
      {
        "step": 19,
        "statusCode": 200,
        "bodyFields": {
          "status": "CANCELLED"
        }
      }
    ],
    "db": [
      {
        "step": 20,
        "checks": ["row exists", "status=CANCELLED"]
      },
      {
        "step": 21,
        "checks": ["no row exists"]
      }
    ]
  }
