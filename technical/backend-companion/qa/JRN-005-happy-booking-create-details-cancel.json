        "venueIds": ["c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a"]
      }
    },
    {
      "step": 10,
      "actor": "InternalAPI",
      "actionType": "apiRequest",
      "method": "POST",
      "endpoint": "/roster-slots/populate-for-companion",
      "headers": {
        "X-Internal-Token": "{{INTERNAL_API_TOKEN}}"
      },
      "description": "Populate roster for COMPANION B at venue",
      "layman": "Attach companion B to the venue and generate their roster slots.",
      "requiredPayloadFields": ["companionId", "venueIds"],
      "payloadRules": {
        "companionIdFromStoreKey": "companionBUserId",
        "venueIds": ["c2c5b5e1-607f-4c6a-a2fb-9c5c1d4c7b2a"]
      }
    },
    {
