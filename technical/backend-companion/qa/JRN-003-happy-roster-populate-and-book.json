{
  "testId": "JRN-003",
  "type": "journey",
  "priority": "P1",
  "scenarioName": "Happy path: CLIENT signup/login -> 2x COMPANION signup/login -> populate roster for venue -> reserve & release roster slots",
  "flowType": "happy",
  "linkedRequirements": [
    "identity/signup",
    "identity/verify-email",
    "identity/login",
    "roster/populate-for-companion",
    "roster/get-availability",
    "roster/reserve-release"
