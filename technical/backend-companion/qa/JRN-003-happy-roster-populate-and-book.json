    "Server running on localhost:3000",
    "Mailpit running on localhost:8025",
    "Docker DB container running (docker compose up -d)",
    "Server configured with INTERNAL_API_TOKEN and the same value exported in the shell running this test (INTERNAL_API_TOKEN)",
    "Server timezone configured consistently (expected TZ=Asia/Dubai for the chosen slot timestamps)"
  ],
