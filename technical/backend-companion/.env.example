NODE_ENV=development
PORT=3000
TZ=Asia/Dubai
DATABASE_URL=postgresql://companion:companion@localhost:5432/companion?schema=public
JWT_SECRET=replace-with-strong-secret-min-32-chars
INTERNAL_API_TOKEN=replace-with-internal-token
BCRYPT_ROUNDS=12
EMAIL_VERIFY_TOKEN_TTL=86400
AUTH_ACCESS_TOKEN_TTL=3600
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=15
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@companion.app
PUBLIC_BASE_URL=http://localhost:3000
WEB_VERIFY_URL=https://companion.app/verify-email?token={token}
