{
  "servers": {
    "test-runner-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/run-server.mjs",
        "test-runner-mcp"
      ],
      "env": {
        "NODE_ENV": "test"
      }
    },
    "project-context-mcp": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/run-server.mjs",
        "project-context-mcp"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    "project-context-mcp-fe": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/mcp/run-server.mjs",
        "project-context-mcp-fe"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    }
  }
}
