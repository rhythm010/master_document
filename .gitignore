# Dependencies (never commit)
node_modules/

# Build output (never commit)
dist/

# Allow committing MCP server dist entrypoint (used by .vscode/mcp.json)
!mcp/test-runner-mcp/dist/
!mcp/test-runner-mcp/dist/index.js

# Allow committing Project Context MCP dist (stdio entrypoint + imports)
!mcp/project-context-mcp/dist/
!mcp/project-context-mcp/dist/**

# Allow committing Frontend Project Context MCP dist (stdio entrypoint + imports)
!mcp/project-context-mcp-fe/dist/
!mcp/project-context-mcp-fe/dist/**

# Environment files
.env
.env.local
.env.*.local

# Logs
*.log
.mcp-usage/

# MCP servers
mcp/**/node_modules/

# macOS
.DS_Store
