generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum ClientBookingStatus {
  NONE
  PENDING
  CONFIRMED
  ACTIVE
}

enum VenueType {
  MALL
  CLUB
  RESTAURANT
}

enum CompanionRole {
  CAPTAIN
  VICE_CAPTAIN
}

enum PenaltyStatus {
  CLEAR
  WARNING
  PENALIZED
}

enum ShiftStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
}

enum AllocationMode {
  AUTO
  CAPTAIN_SPECIFIED
  VICE_CAPTAIN_SPECIFIED
  BOTH_SPECIFIED
}

enum DuoStatus {
  PENDING
  MATCHED
  ACTIVATED
  BREACH
}

enum PaymentHoldStatus {
  NONE
  HELD
  CHARGED
  VOIDED
  REFUNDED
}

enum CancelledBy {
  CLIENT
  ADMIN
  SYSTEM
}

enum AuditAction {
  CREATED
  CONFIRMED
  CANCELLED
  REALLOCATED
  STARTED
  COMPLETED
  FAILED
  REFUNDED
  AUTO_CANCELLED_BREACH
  AUTO_COMPLETED_NO_SHOW
  ADMIN_OVERRIDE
}

enum ActorType {
  CLIENT
  COMPANION
  ADMIN
  SYSTEM
}

enum NotificationType {
  BATTERY_CHECK
  MATCH_PENDING
  LOCATION_CONFIRM
  BOOKING_CONFIRMED
  COMPANIONS_READY
  ESCALATION_CALL
  CANCELLATION
  REMINDER
  BREACH_ALERT
}

enum NotificationChannel {
  PUSH
  SMS
  AUTOMATED_CALL
}

enum NotificationStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum PenaltyType {
  SHIFT_CANCELLATION
  BREACH
  NO_SHOW
  LATE_ARRIVAL
  OTHER
}

enum PenaltySeverity {
  LOW
  MEDIUM
  HIGH
}

enum PenaltyIssuer {
  SYSTEM
  ADMIN
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
  OPERATIONS
}

// ─── Models ──────────────────────────────────────────

model Client {
  id                    String              @id @default(uuid()) @db.Uuid
  fullName              String              @map("full_name")
  nickname              String
  phoneNumber           String              @unique @map("phone_number")
  email                 String?
  profileLanguage       String              @default("EN") @map("profile_language")
  paymentMethodToken    String?             @map("payment_method_token")
  pushNotificationToken String?             @map("push_notification_token")
  deviceId              String?             @map("device_id")
  currentBookingId      String?             @unique @map("current_booking_id") @db.Uuid
  bookingStatusCache    ClientBookingStatus @default(NONE) @map("booking_status_cache")
  gpsPermissionGranted  Boolean             @default(false) @map("gps_permission_granted")
  lastKnownLatitude     Decimal?            @map("last_known_latitude") @db.Decimal(10, 7)
  lastKnownLongitude    Decimal?            @map("last_known_longitude") @db.Decimal(10, 7)
  lastGpsUpdateAt       DateTime?           @map("last_gps_update_at")
  consentVersion        String?             @map("consent_version")
  consentAcceptedAt     DateTime?           @map("consent_accepted_at")
  averageRating         Decimal?            @map("average_rating") @db.Decimal(3, 2)
  totalBookings         Int                 @default(0) @map("total_bookings")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  currentBooking Booking?  @relation("CurrentBooking", fields: [currentBookingId], references: [id])
  bookings       Booking[] @relation("ClientBookings")

  @@map("clients")
}

model Companion {
  id                    String        @id @default(uuid()) @db.Uuid
  fullName              String        @map("full_name")
  phoneNumber           String        @unique @map("phone_number")
  email                 String?
  role                  CompanionRole
  isActive              Boolean       @default(true) @map("is_active")
  physicalStats         Json?         @map("physical_stats")
  languageSkills        Json          @map("language_skills")
  backgroundVerified    Boolean       @default(false) @map("background_verified")
  pushNotificationToken String?       @map("push_notification_token")
  deviceId              String?       @map("device_id")
  currentShiftId        String?       @map("current_shift_id") @db.Uuid
  gpsEnabled            Boolean       @default(false) @map("gps_enabled")
  lastKnownLatitude     Decimal?      @map("last_known_latitude") @db.Decimal(10, 7)
  lastKnownLongitude    Decimal?      @map("last_known_longitude") @db.Decimal(10, 7)
  lastGpsUpdateAt       DateTime?     @map("last_gps_update_at")
  penaltyStatus         PenaltyStatus @default(CLEAR) @map("penalty_status")
  averageRating         Decimal?      @map("average_rating") @db.Decimal(3, 2)
  totalSessions         Int           @default(0) @map("total_sessions")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  currentShift        Shift?    @relation("CurrentShift", fields: [currentShiftId], references: [id])
  shifts              Shift[]   @relation("CompanionShifts")
  captainBookings     Booking[] @relation("CaptainBookings")
  viceCaptainBookings Booking[] @relation("ViceCaptainBookings")
  penalties           Penalty[]

  @@map("companions")
}

model Venue {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  type                VenueType
  address             String
  latitude            Decimal   @db.Decimal(10, 7)
  longitude           Decimal   @db.Decimal(10, 7)
  country             String
  operatingHoursStart String    @map("operating_hours_start")
  operatingHoursEnd   String    @map("operating_hours_end")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  bookings Booking[]

  @@map("venues")
}

model Shift {
  id                 String      @id @default(uuid()) @db.Uuid
  companionId        String      @map("companion_id") @db.Uuid
  date               DateTime    @db.Date
  startTime          String      @map("start_time")
  endTime            String      @map("end_time")
  status             ShiftStatus @default(SCHEDULED)
  cancellationReason String?     @map("cancellation_reason")
  cancelledAt        DateTime?   @map("cancelled_at")
  penaltyApplied     Boolean     @default(false) @map("penalty_applied")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  companion           Companion   @relation("CompanionShifts", fields: [companionId], references: [id])
  currentCompanion    Companion[] @relation("CurrentShift")
  captainBookings     Booking[]   @relation("CaptainShiftBookings")
  viceCaptainBookings Booking[]   @relation("ViceCaptainShiftBookings")

  @@index([companionId, date])
  @@index([date, status])
  @@map("shifts")
}

model Booking {
  id                             String            @id @default(uuid()) @db.Uuid
  clientId                       String            @map("client_id") @db.Uuid
  venueId                        String            @map("venue_id") @db.Uuid
  captainId                      String?           @map("captain_id") @db.Uuid
  viceCaptainId                  String?           @map("vice_captain_id") @db.Uuid
  allocationMode                 AllocationMode    @default(AUTO) @map("allocation_mode")
  captainShiftId                 String?           @map("captain_shift_id") @db.Uuid
  viceCaptainShiftId             String?           @map("vice_captain_shift_id") @db.Uuid
  clientNicknameSnapshot         String            @map("client_nickname_snapshot")
  duoStatus                      DuoStatus         @default(PENDING) @map("duo_status")
  duoMatchedAt                   DateTime?         @map("duo_matched_at")
  duoActivatedAt                 DateTime?         @map("duo_activated_at")
  duoBreachReportedAt            DateTime?         @map("duo_breach_reported_at")
  duoQrCode                      String?           @map("duo_qr_code")
  duoPinCode                     String?           @map("duo_pin_code") @db.VarChar(6)
  captainLocationConfirmedAt     DateTime?         @map("captain_location_confirmed_at")
  viceCaptainLocationConfirmedAt DateTime?         @map("vice_captain_location_confirmed_at")
  date                           DateTime          @db.Date
  startTime                      String            @map("start_time")
  endTime                        String            @map("end_time")
  durationMinutes                Int               @default(120) @map("duration_minutes")
  status                         BookingStatus     @default(PENDING)
  baseRate                       Decimal           @map("base_rate") @db.Decimal(10, 2)
  vatAmount                      Decimal           @map("vat_amount") @db.Decimal(10, 2)
  serviceFee                     Decimal           @map("service_fee") @db.Decimal(10, 2)
  grandTotal                     Decimal           @map("grand_total") @db.Decimal(10, 2)
  paymentHoldStatus              PaymentHoldStatus @default(NONE) @map("payment_hold_status")
  paymentHoldAmount              Decimal?          @map("payment_hold_amount") @db.Decimal(10, 2)
  softLockExpiresAt              DateTime?         @map("soft_lock_expires_at")
  qrCode                         String?           @map("qr_code")
  pinCode                        String?           @map("pin_code") @db.VarChar(4)
  consentAccepted                Boolean           @default(false) @map("consent_accepted")
  consentVersionAccepted         String?           @map("consent_version_accepted")
  bookingNotes                   String?           @map("booking_notes")
  failureReason                  String?           @map("failure_reason")
  cancellationReason             String?           @map("cancellation_reason")
  cancelledBy                    CancelledBy?      @map("cancelled_by")
  cancelledAt                    DateTime?         @map("cancelled_at")
  refundAmount                   Decimal?          @map("refund_amount") @db.Decimal(10, 2)
  refundPercentage               Int?              @map("refund_percentage")
  sessionStartedAt               DateTime?         @map("session_started_at")
  sessionEndedAt                 DateTime?         @map("session_ended_at")
  clientNoShow                   Boolean           @default(false) @map("client_no_show")
  createdAt                      DateTime          @default(now()) @map("created_at")
  updatedAt                      DateTime          @updatedAt @map("updated_at")

  client           Client            @relation("ClientBookings", fields: [clientId], references: [id])
  currentClient    Client?           @relation("CurrentBooking")
  venue            Venue             @relation(fields: [venueId], references: [id])
  captain          Companion?        @relation("CaptainBookings", fields: [captainId], references: [id])
  viceCaptain      Companion?        @relation("ViceCaptainBookings", fields: [viceCaptainId], references: [id])
  captainShift     Shift?            @relation("CaptainShiftBookings", fields: [captainShiftId], references: [id])
  viceCaptainShift Shift?            @relation("ViceCaptainShiftBookings", fields: [viceCaptainShiftId], references: [id])
  auditLogs        BookingAuditLog[]
  notifications    NotificationLog[]
  penalties        Penalty[]

  @@index([clientId, status])
  @@index([captainId, date])
  @@index([viceCaptainId, date])
  @@index([status, date])
  @@index([softLockExpiresAt])
  @@index([date, startTime])
  @@map("bookings")
}

model BookingAuditLog {
  id                      String      @id @default(uuid()) @db.Uuid
  bookingId               String      @map("booking_id") @db.Uuid
  action                  AuditAction
  performedByType         ActorType   @map("performed_by_type")
  performedById           String      @map("performed_by_id") @db.Uuid
  deviceId                String?     @map("device_id")
  pricingEngineVersion    String?     @map("pricing_engine_version")
  allocationEngineVersion String?     @map("allocation_engine_version")
  clientLatitude          Decimal?    @map("client_latitude") @db.Decimal(10, 7)
  clientLongitude         Decimal?    @map("client_longitude") @db.Decimal(10, 7)
  metadata                Json?
  createdAt               DateTime    @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([createdAt])
  @@map("booking_audit_logs")
}

model NotificationLog {
  id               String              @id @default(uuid()) @db.Uuid
  recipientType    ActorType           @map("recipient_type")
  recipientId      String              @map("recipient_id") @db.Uuid
  bookingId        String?             @map("booking_id") @db.Uuid
  notificationType NotificationType    @map("notification_type")
  channel          NotificationChannel
  content          String?
  status           NotificationStatus  @default(SENT)
  createdAt        DateTime            @default(now()) @map("created_at")

  booking Booking? @relation(fields: [bookingId], references: [id])

  @@index([recipientId, recipientType])
  @@index([bookingId])
  @@map("notification_logs")
}

model Penalty {
  id          String          @id @default(uuid()) @db.Uuid
  companionId String          @map("companion_id") @db.Uuid
  shiftId     String?         @map("shift_id") @db.Uuid
  bookingId   String?         @map("booking_id") @db.Uuid
  type        PenaltyType
  reason      String
  severity    PenaltySeverity
  issuedBy    PenaltyIssuer   @map("issued_by")
  issuedAt    DateTime        @default(now()) @map("issued_at")
  resolved    Boolean         @default(false)
  resolvedAt  DateTime?       @map("resolved_at")

  companion Companion @relation(fields: [companionId], references: [id])
  booking   Booking?  @relation(fields: [bookingId], references: [id])

  @@index([companionId])
  @@map("penalties")
}

model Admin {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  email       String    @unique
  password    String
  role        AdminRole
  permissions Json
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("admins")
}
